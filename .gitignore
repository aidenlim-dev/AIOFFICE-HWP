# dependencies
node_modules/
.pnp
.pnp.js

# aioffice-capture — Hancom Docs login session & browser profile.
# auth.json IS a live login session; pw-profile is a browser data dir.
# NEVER commit these (per-machine, one-time login). Belt-and-suspenders on
# top of the plugin's own patterns.
**/auth.json
**/pw-profile/

# build
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor
.vscode/
.idea/
*.swp
.DS_Store

# test / coverage
coverage/
.nyc_output/
__pycache__/
*.py[cod]

# claude
.claude/settings.local.json

# scratch / spike work
spike/

# internal-only docs (marketing / strategy notes shared across local sessions)
_*.md

# internal-only / cross-project notes — never publish
*SNAPSHOT*
*_NOTES.md

# dev-internal docs (per-developer working notes, not user-facing)
# Plugin marketplace only fetches plugins/aioffice-hwp/ — these top-level
# files aren't useful in the public repo or to plugin users.
CLAUDE.md
VERIFIED_BEHAVIORS.md

# verified hwpx samples — DO NOT DELETE. Local-only, never publish.
_verified_hwpx_samples/

# dev-internal: handoff docs (track-to-track / session continuity) + experiment
# sandbox (secure-fill test harnesses). Not part of the shipped plugin, not
# auto-loaded by the cold-start skill — keep out of the public repo. They recur
# at the root during dev, so ignore the patterns.
/*HANDOFF*.md
experiment/
